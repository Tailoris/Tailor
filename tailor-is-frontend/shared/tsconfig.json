{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "baseUrl": ".",
    "paths": {
      "vue": ["../pc-mall/node_modules/vue"],
      "pinia": ["../pc-mall/node_modules/pinia"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}
