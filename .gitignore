# ============================================================
# Tailor IS 项目 .gitignore
# ============================================================

# ===== 敏感信息（CRITICAL） =====
.env
.env.local
.env.production
**/*.pem
**/*.key
**/credentials.json
**/secrets.yml

# ===== IDE =====
.idea/
.vscode/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/

# ===== Java / Maven =====
target/
*.class
*.jar
*.war
*.ear
*.log
*.pid
hs_err_pid*

# ===== Node.js / 前端 =====
node_modules/
dist/
.nuxt/
.output/
.turbo/
*.tsbuildinfo
.eslintcache

# ===== Docker =====
docker-compose.override.yml

# ===== OS =====
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ===== 临时文件 =====
*.tmp
*.bak
*.cache
__pycache__/
*.pyc

# ===== 日志 =====
logs/
*.log

# ===== 构建产物 =====
build/
out/
.gradle/

# ===== 测试覆盖率 =====
coverage/
.nyc_output/
jacoco/

# ===== SonarQube =====
.sonar/
.scannerwork/
