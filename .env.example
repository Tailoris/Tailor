# ==============================================================================
# Tailor IS (裁智云) - 环境变量配置模板
# ==============================================================================
# 使用方法:
#   1. 复制此文件: cp .env.example .env
#   2. 将所有 <PLEASE_SET> 和 <PLEASE_GENERATE> 替换为真实值
#   3. 生产环境密码必须使用强密码 (至少16位, 包含大小写字母、数字、特殊字符)
# ==============================================================================

# ===== 数据库 =====
# MySQL 连接配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USERNAME=root
MYSQL_PASSWORD=<PLEASE_SET>
# MySQL root 用户密码 (Docker Compose 使用)
MYSQL_ROOT_PASSWORD=<PLEASE_SET>

# ===== Redis =====
# Redis 连接配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<PLEASE_SET>

# ===== Nacos =====
# Nacos 服务发现与配置中心
NACOS_ADDR=localhost:8848
NACOS_USERNAME=nacos
NACOS_PASSWORD=<PLEASE_SET>
# Nacos 身份验证 (Docker Compose 兼容)
NACOS_AUTH_IDENTITY_KEY=serverIdentity
NACOS_AUTH_IDENTITY_VALUE=<PLEASE_SET>
NACOS_AUTH_TOKEN=<PLEASE_GENERATE>

# ===== RabbitMQ =====
# RabbitMQ 消息队列
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
# Docker Compose 默认用户
RABBITMQ_DEFAULT_USER=rabbitmq
RABBITMQ_DEFAULT_PASS=<PLEASE_SET>
# 微服务使用的变量名
RABBITMQ_USERNAME=rabbitmq
RABBITMQ_PASSWORD=<PLEASE_SET>

# ===== CORS =====
# 允许的前端跨域来源 (逗号分隔)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ===== 服务端口 =====
# 各微服务的本地映射端口 (冲突时可修改)
GATEWAY_PORT=9000
LITE_GATEWAY_PORT=8081
USER_PORT=8101
PRODUCT_PORT=8102
ORDER_PORT=8103
PAYMENT_PORT=8104
MARKETING_PORT=8105
AI_PORT=8106
COPYRIGHT_PORT=8107
COMMUNITY_PORT=8108
SUPPLY_PORT=8109
MESSAGE_PORT=8111
MERCHANT_PORT=8110
ACADEMY_PORT=8112

# ===== Snowflake =====
# 分布式 ID 生成器 (不同实例必须使用不同的 ID)
SNOWFLAKE_WORKER_ID=0
SNOWFLAKE_DATACENTER_ID=0

# ===== 监控 =====
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_PASSWORD=<PLEASE_SET>

# ===== 支付 =====
# 微信支付
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_KEY=
WECHAT_PAY_NOTIFY_URL=https://api.tailoris.com/api/v1/payment/wechat/callback

# 支付宝
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# ===== 安全 =====
# AES 加密密钥 (16/24/32 字节, Base64 编码)
AES_KEY=<PLEASE_GENERATE>
