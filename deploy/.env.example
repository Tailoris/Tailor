# =====================================================================
# Tailor IS 生产环境变量模板
# =====================================================================
# 使用方式:
#   cp deploy/.env.example .env
#   chmod 600 .env
#   # 然后编辑 .env 填入真实值
#
# 安全注意:
#   - .env 文件不要提交到代码仓库 (已在 .gitignore 中排除)
#   - 生产环境的真实密码必须通过 CI/CD secret 注入或 K8s Secret
#   - 所有标记为必填的变量必须填写，否则 docker compose 启动失败
# =====================================================================

# ---------------------------------------------------------------------
# 运行模式
# ---------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=prod
TZ=Asia/Shanghai

# ---------------------------------------------------------------------
# MySQL 数据库 (必填)
# ---------------------------------------------------------------------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>

# 各业务库独立 JDBC URL (已在 docker-compose 中按需引用)
MYSQL_USER_URL=jdbc:mysql://host.docker.internal:3306/tailor_is_user?useUnicode=true&characterEncoding=utf-8&useSSL=true&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
MYSQL_PRODUCT_URL=jdbc:mysql://host.docker.internal:3306/tailor_is_product?useUnicode=true&characterEncoding=utf-8&useSSL=true&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
MYSQL_ORDER_URL=jdbc:mysql://host.docker.internal:3306/tailor_is_order?useUnicode=true&characterEncoding=utf-8&useSSL=true&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
MYSQL_PAYMENT_URL=jdbc:mysql://host.docker.internal:3306/tailor_is_payment?useUnicode=true&characterEncoding=utf-8&useSSL=true&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
MYSQL_MARKETING_URL=jdbc:mysql://host.docker.internal:3306/tailor_is_marketing?useUnicode=true&characterEncoding=utf-8&useSSL=true&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
MYSQL_AI_URL=jdbc:mysql://host.docker.internal:3306/tailor_is_ai?useUnicode=true&characterEncoding=utf-8&useSSL=true&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
MYSQL_COPYRIGHT_URL=jdbc:mysql://host.docker.internal:3306/tailor_is_copyright?useUnicode=true&characterEncoding=utf-8&useSSL=true&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
MYSQL_MERCHANT_URL=jdbc:mysql://host.docker.internal:3306/tailor_is_merchant?useUnicode=true&characterEncoding=utf-8&useSSL=true&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
MYSQL_ADMIN_URL=jdbc:mysql://host.docker.internal:3306/tailor_is_admin?useUnicode=true&characterEncoding=utf-8&useSSL=true&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
MYSQL_PATTERN_URL=jdbc:mysql://host.docker.internal:3306/tailor_is_pattern?useUnicode=true&characterEncoding=utf-8&useSSL=true&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
MYSQL_COMMUNITY_URL=jdbc:mysql://host.docker.internal:3306/tailor_is_community?useUnicode=true&characterEncoding=utf-8&useSSL=true&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
MYSQL_SUPPLY_URL=jdbc:mysql://host.docker.internal:3306/tailor_is_supply?useUnicode=true&characterEncoding=utf-8&useSSL=true&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
MYSQL_MESSAGE_URL=jdbc:mysql://host.docker.internal:3306/tailor_is_message?useUnicode=true&characterEncoding=utf-8&useSSL=true&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
MYSQL_IM_URL=jdbc:mysql://host.docker.internal:3306/tailor_is_im?useUnicode=true&characterEncoding=utf-8&useSSL=true&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
MYSQL_ACADEMY_URL=jdbc:mysql://host.docker.internal:3306/tailor_is_academy?useUnicode=true&characterEncoding=utf-8&useSSL=true&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
MYSQL_ANALYTICS_URL=jdbc:mysql://host.docker.internal:3306/tailor_is_analytics?useUnicode=true&characterEncoding=utf-8&useSSL=true&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true

# ---------------------------------------------------------------------
# Redis 缓存 (必填)
# ---------------------------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>

# ---------------------------------------------------------------------
# RabbitMQ 消息队列 (必填)
# ---------------------------------------------------------------------
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_DEFAULT_USER=<CHANGE_ME>
RABBITMQ_DEFAULT_PASS=<CHANGE_ME_STRONG_PASSWORD>

# ---------------------------------------------------------------------
# Nacos 服务注册中心/配置中心 (必填)
# ---------------------------------------------------------------------
NACOS_ADDR=host.docker.internal:8848
NACOS_AUTH_TOKEN=<CHANGE_ME_RANDOM_64_CHAR_HEX>
NACOS_AUTH_IDENTITY_KEY=serverIdentity
NACOS_AUTH_IDENTITY_VALUE=<CHANGE_ME>

# ---------------------------------------------------------------------
# Grafana 监控面板 (必填)
# ---------------------------------------------------------------------
GRAFANA_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>
GRAFANA_ADMIN_USER=admin

# ---------------------------------------------------------------------
# 网关 HMAC 签名密钥 (必填)
# 用于网关对 X-User-Id 签名，下游服务校验
# 生成方式: openssl rand -base64 32
# ---------------------------------------------------------------------
GATEWAY_HMAC_SECRET=<CHANGE_ME_RANDOM_BASE64_32>

# ---------------------------------------------------------------------
# 安全配置 (必填)
# ---------------------------------------------------------------------
JWT_SECRET=<CHANGE_ME_RANDOM_STRING>
AES_KEY=<CHANGE_ME_RANDOM_32_CHAR>

# ---------------------------------------------------------------------
# 告警通知 (可选)
# ---------------------------------------------------------------------
DINGTALK_WEBHOOK=
DINGTALK_SECRET=
FEISHU_WEBHOOK=
WECOM_WEBHOOK=

# ---------------------------------------------------------------------
# 对象存储 (可选)
# ---------------------------------------------------------------------
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# ---------------------------------------------------------------------
# 邮件服务 (可选)
# ---------------------------------------------------------------------
EMAIL_FROM=noreply@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=