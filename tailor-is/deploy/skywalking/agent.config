# ==============================================================================
# SkyWalking Java Agent 配置
# ==============================================================================
# 使用方法:
#   java -javaagent:/path/to/skywalking-agent.jar \
#        -Dskywalking_config=/path/to/agent.config \
#        -jar your-app.jar
#
# 或在 Dockerfile 中:
#   ENV SW_AGENT_COLLECTOR_BACKEND_SERVICES=skywalking-oap:11800
#   ENV SW_AGENT_NAME=tailor-is-order
# ==============================================================================

# SkyWalking OAP 服务地址
agent.service_name=${SW_AGENT_NAME:tailor-is-app}
collector.backend_service=${SW_AGENT_COLLECTOR_BACKEND_SERVICES:skywalking-oap:11800}

# 日志级别
logging.level=${SW_LOGGING_LEVEL:INFO}

# ==============================================================================
# 采样率配置
# ==============================================================================
# agent.sample_n_per_3_secs: 每 3 秒采集的 Trace 数量
#   -1  = 全采样 (开发/测试环境推荐)
#   0   = 不采样
#   N   = 每 3 秒最多采集 N 条 Trace (生产环境推荐值: 500~1000)
# ==============================================================================
agent.sample_n_per_3_secs=-1

# 忽略指定 URL 的 Trace (健康检查端点)
trace.ignore_path=${SW_TRACE_IGNORE_PATH:/actuator/health/**,/actuator/info/**,/actuator/prometheus/**}

# 最大 Span 数量限制 (防止内存溢出)
agent.span_limit_per_segment=${SW_SPAN_LIMIT:300}