<?xml version="1.0" encoding="UTF-8"?>
<ruleset name="Tailor IS PMD Ruleset"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0
                             http://pmd.sourceforge.net/ruleset_2_0_0.xsd">

    <description>
        Tailor IS 项目 PMD 静态分析规则集
        基于 PMD 7.x best practices + 阿里 Java 开发手册约束
    </description>

    <!-- 最佳实践 -->
    <rule ref="category/java/bestpractices.xml">
        <exclude name="UseTryWithResources"/>           <!-- Spring 项目允许显式 close -->
        <exclude name="PreserveStackTrace"/>            <!-- 大量误报 -->
        <exclude name="SystemPrintln"/>                 <!-- 重复检查由 checkstyle 处理 -->
        <exclude name="ForLoopCanBeForeach"/>
    </rule>

    <!-- 代码风格 -->
    <rule ref="category/java/codestyle.xml">
        <exclude name="AtLeastOneConstructor"/>         <!-- DTO 允许无显式构造 -->
        <exclude name="CommentDefaultAccessModifier"/>
        <exclude name="ConfusingTernary"/>
        <exclude name="LongVariable"/>
        <exclude name="ShortVariable"/>
        <exclude name="OnlyOneReturn"/>
        <exclude name="TooManyStaticImports"/>
        <exclude name="UnnecessaryAnnotationValueElement"/>
        <exclude name="UnnecessaryBoxing"/>
        <exclude name="UnnecessaryFullyQualifiedName"/>
        <exclude name="UnnecessaryImport"/>
        <exclude name="UnnecessaryLocalBeforeReturn"/>
        <exclude name="UnnecessaryModifier"/>
        <exclude name="UnnecessaryReturn"/>
        <exclude name="UselessParentheses"/>
        <exclude name="UseDiamondOperator"/>
    </rule>

    <!-- 设计 -->
    <rule ref="category/java/design.xml">
        <exclude name="LawOfDemeter"/>
        <exclude name="LoosePackageCoupling"/>
        <exclude name="ExcessiveImports"/>
        <exclude name="ExcessiveParameterList"/>
        <exclude name="DataClass"/>
    </rule>

    <!-- 错误易发 -->
    <rule ref="category/java/errorprone.xml">
        <exclude name="BeanMembersShouldSerialize"/>    <!-- 与 DTO 设计冲突 -->
        <exclude name="DataflowAnomalyAnalysis"/>        <!-- 性能差 -->
        <exclude name="MissingSerialVersionUID"/>        <!-- 框架生成类豁免 -->
    </rule>

    <!-- 多线程(选择性) -->
    <rule ref="category/java/multithreading.xml">
        <exclude name="AvoidUsingVolatile"/>
        <exclude name="DontUseThread"/>
    </rule>

    <!-- 性能 -->
    <rule ref="category/java/performance.xml">
        <exclude name="AddEmptyString"/>
        <exclude name="AppendCharacterWithChar"/>
        <exclude name="AvoidFileStream"/>
    </rule>

    <!-- 安全(代码安全, OWASP 相关) -->
    <rule ref="category/java/security.xml"/>

    <!-- ============ 自定义规则 ============ -->

    <rule name="TailorISLogConvention"
          language="java"
          message="Logger 字段命名必须为 'log' 或 'logger'"
          class="net.sourceforge.pmd.lang.rule.xpath.XPathRule">
        <description>统一日志对象命名</description>
        <priority>3</priority>
        <properties>
            <property name="xpath">
                <value>
//FieldDeclaration/VariableDeclaratorId[@Name != 'log' and @Name != 'logger' and @Name != 'LOG' and @Name != 'LOGGER']
/../..[TypeReference/ClassOrInterfaceType[@Name='Logger']]
                </value>
            </property>
        </properties>
    </rule>

    <rule name="TailorISNoMagicNumberInBusiness"
          language="java"
          message="业务代码中应避免魔法数字, 请定义常量"
          class="net.sourceforge.pmd.lang.rule.xpath.XPathRule">
        <description>业务层禁止使用 0/1/-1 之外的数字字面量</description>
        <priority>4</priority>
        <properties>
            <property name="xpath">
                <value>
//NumericLiteral[not(@Image='0') and not(@Image='1') and not(@Image='2') and not(@Image='-1') and not(@Image='100') and not(@Image='1000')]
                </value>
            </property>
        </properties>
    </rule>

</ruleset>
