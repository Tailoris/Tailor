<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
  Tailor IS 项目 Checkstyle 配置
  基于阿里 Java 开发手册 + Google Java Style 定制
-->
<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="severity" value="warning"/>
    <property name="fileExtensions" value="java, properties, xml"/>

    <!-- 源码文件制表符宽度 -->
    <property name="tabWidth" value="4"/>

    <!-- 允许的最大行长度 -->
    <module name="LineLength">
        <property name="max" value="160"/>
        <property name="ignorePattern" value="^package.*|^import.*|a href|href|http://|https://|ftp://"/>
    </module>

    <!-- 文件结尾必须换行 -->
    <module name="NewlineAtEndOfFile">
        <property name="lineSeparator" value="lf_cr_crlf"/>
    </module>

    <!-- 翻译: TreeWalker 模块执行大多数检查 -->
    <module name="TreeWalker">

        <!-- 不允许 Tab 字符 -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="\t"/>
            <property name="message" value="禁止使用 Tab 字符，请使用 4 个空格"/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- ============ 命名规范 ============ -->

        <!-- 包名全小写 -->
        <module name="PackageName">
            <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
            <message key="name.invalidPattern"
                     value="包名必须全小写: ''{0}''"/>
        </module>

        <!-- 类名: PascalCase -->
        <module name="TypeName">
            <property name="format" value="^[A-Z][a-zA-Z0-9]*$"/>
        </module>

        <!-- 方法名: camelCase -->
        <module name="MethodName">
            <property name="format" value="^[a-z][a-zA-Z0-9_]*$"/>
        </module>

        <!-- 变量名: camelCase -->
        <module name="LocalVariableName">
            <property name="format" value="^[a-z][a-zA-Z0-9_]*$"/>
        </module>

        <!-- 成员变量: camelCase -->
        <module name="MemberName">
            <property name="format" value="^[a-z][a-zA-Z0-9_]*$"/>
        </module>

        <!-- 参数名 -->
        <module name="ParameterName">
            <property name="format" value="^[a-z][a-zA-Z0-9_]*$"/>
        </module>

        <!-- 常量全大写下划线 -->
        <module name="ConstantName">
            <property name="format" value="^[A-Z][A-Z0-9_]*$"/>
        </module>

        <!-- ============ 导入规范 ============ -->

        <!-- 避免使用 * 通配符导入 -->
        <module name="AvoidStarImport">
            <property name="allowClassImports" value="false"/>
            <property name="allowStaticMemberImports" value="false"/>
        </module>

        <!-- 检查未使用导入 -->
        <module name="UnusedImports">
            <property name="processJavadoc" value="true"/>
        </module>

        <!-- ============ 代码风格 ============ -->

        <!-- 大括号: K&R 风格 -->
        <module name="LeftCurly">
            <property name="option" value="eol"/>
        </module>

        <!-- 右大括号独立成行 -->
        <module name="RightCurly">
            <property name="option" value="alone"/>
        </module>

        <!-- else/finally 等必须使用大括号 -->
        <module name="NeedBraces">
            <property name="allowSingleLineStatement" value="false"/>
        </module>

        <!-- 缩进 4 空格 -->
        <module name="Indentation">
            <property name="basicOffset" value="4"/>
            <property name="braceAdjustment" value="0"/>
            <property name="caseIndent" value="4"/>
            <property name="throwsIndent" value="4"/>
            <property name="lineWrappingIndentation" value="4"/>
            <property name="arrayInitIndent" value="4"/>
        </module>

        <!-- 一行声明一个变量 -->
        <module name="MultipleVariableDeclarations"/>

        <!-- 禁止数字字面量后缀(避免 l/L 误用) -->
        <module name="UpperEll"/>

        <!-- 默认访问修饰符省略 -->
        <module name="RedundantModifier"/>

        <!-- ============ 复杂度与可维护性 ============ -->

        <!-- 单方法最大行数 -->
        <module name="MethodLength">
            <property name="max" value="200"/>
        </module>

        <!-- 单方法最大参数数 -->
        <module name="ParameterNumber">
            <property name="max" value="8"/>
        </module>

        <!-- 嵌套深度 -->
        <module name="NestedIfDepth">
            <property name="max" value="3"/>
        </module>

        <module name="NestedTryDepth">
            <property name="max" value="2"/>
        </module>

        <!-- 禁止空 catch 块 -->
        <module name="EmptyCatchBlock">
            <property name="exceptionVariableName" value="^(e|ex|exception)$"/>
        </module>

        <!-- Switch 必须有 default 分支 -->
        <module name="MissingSwitchDefault"/>

        <!-- equals 必须比较常量在前 -->
        <module name="EqualsHashCode"/>

        <!-- String 比较必须用 equals -->
        <module name="StringLiteralEquality"/>

        <!-- 简化布尔表达式 -->
        <module name="SimplifyBooleanExpression"/>

        <!-- 简化条件返回 -->
        <module name="SimplifyBooleanReturn"/>

    </module>
</module>
